{
  "name": "client-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/client/ui/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/client-ui",
        "main": "libs/client/ui/src/index.ts",
        "tsConfig": "libs/client/ui/tsconfig.lib.json",
        "assets": ["libs/client/ui/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/client/ui/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo No tests",
        "passWithNoTests": true
      }
    }
  }
}
