{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/libs/client-shared",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "lib": ["dom", "es2022"],
    "types": ["node"],
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
  ],
}
