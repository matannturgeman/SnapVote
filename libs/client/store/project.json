{
  "name": "client-store",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/client/store/src",
  "projectType": "library",
  "tags": ["scope:client", "type:store"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputPath}"],
      "options": {
        "cwd": "libs/client/store",
        "command": "node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync('dist',{recursive:true});fs.readdirSync('src').forEach(f=>{const s=p.join('src',f);const d=p.join('dist',f);fs.statSync(s).isDirectory()?fs.cpSync(s,d,{recursive:true}):fs.copyFileSync(s,d)})\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo No tests"
      }
    }
  }
}
