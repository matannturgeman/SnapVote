{
  "name": "client-store",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/client/store/src",
  "projectType": "library",
  "tags": ["scope:client", "type:store"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/client-store",
        "tsConfig": "libs/client/store/tsconfig.lib.json",
        "packageJson": "libs/client/store/package.json",
        "main": "libs/client/store/src/index.ts",
        "assets": []
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/client/store/tsconfig.lib.json --noEmit"
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/client/store/jest.config.js"
      }
    }
  }
}
