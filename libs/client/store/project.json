{
  "name": "client-store",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/client/store/src",
  "projectType": "library",
  "tags": ["scope:client", "type:store"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/client-store",
        "main": "libs/client/store/src/index.ts",
        "tsConfig": "libs/client/store/tsconfig.lib.json",
        "assets": ["libs/client/store/*.md"],
        "declaration": false,
        "declarationMap": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests'",
        "passWithNoTests": true
      }
    }
  }
}
