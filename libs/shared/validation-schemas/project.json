{
  "name": "shared-validation-schemas",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/validation-schemas/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:validation"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared-validation-schemas",
        "main": "libs/shared/validation-schemas/src/index.ts",
        "tsConfig": "libs/shared/validation-schemas/tsconfig.lib.json",
        "assets": ["libs/shared/validation-schemas/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/shared/validation-schemas/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/validation-schemas/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
