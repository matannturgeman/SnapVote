{
  "name": "api",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        }
      ],
      "outputs": ["{workspaceRoot}/dist/api"],
      "options": {
        "command": "webpack --mode production",
        "cwd": "apps/api"
      },
      "configurations": {
        "development": {
          "command": "webpack --mode development --watch",
          "cwd": "apps/api"
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "npm run build:api && node dist/api/main.js",
        "cwd": ".",
        "runBuildTargetDependencies": true
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/api/main.js --watch",
        "cwd": "."
      },
      "configurations": {
        "production": {},
        "development": {}
      }
    },
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/api",
        "command": "eslint src --config ../../eslint.config.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/api",
        "command": "npx tsc --noEmit -p tsconfig.app.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "apps/api/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
