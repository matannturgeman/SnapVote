NODE_ENV=production
HOST=0.0.0.0
PORT=10000
API_PREFIX=api

# Database (Neon) - set in Render env vars
# DATABASE_URL=

# Redis (Upstash) - set in Render env vars
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Frontend URL - set in Render env vars
# FRONTEND_URL=

# Auth - set in Render env vars
# AUTH_SESSION_TTL_SECONDS=604800
# AUTH_RESET_TOKEN_TTL_MINUTES=15
# AUTH_REQUIRE_EMAIL_TRANSPORT=false

# SMTP (Resend) - set in Render env vars
# SMTP_PASS=
# SMTP_FROM=