# API server
NODE_ENV=development
HOST=localhost
PORT=3000
API_PREFIX=api
CLIENT_URL=http://localhost:4200

# Database
DATABASE_URL=postgresql://nxuser:nxpass@localhost:5432/nxdb
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nxuser
DATABASE_PASS=nxpass
DATABASE_NAME=nxdb

# Cache / optional infra
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
AUTH_SESSION_TTL_SECONDS=604800
AUTH_RESET_TOKEN_TTL_MINUTES=15
AUTH_REQUIRE_EMAIL_TRANSPORT=false

# Password reset link base
# Option A: Full reset page URL, token will be appended as query param
AUTH_RESET_PASSWORD_URL_BASE=http://localhost:4200/reset-password

# SMTP (required in production for forgot-password emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
