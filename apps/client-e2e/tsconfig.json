{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "lib": ["es2022", "dom"],
    "outDir": "../../dist/out-tsc",
    "sourceMap": false,
    "module": "commonjs",
    "moduleResolution": "node10"
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.d.ts"
  ],
  "references": [
    { "path": "../../libs/client/shared/tsconfig.lib.json" },
    { "path": "../../libs/shared/validation-schemas/tsconfig.lib.json" },
    { "path": "../../libs/shared/dto/tsconfig.lib.json" },
    { "path": "../../libs/client/server-communication/tsconfig.lib.json" },
    { "path": "../../libs/client/store/tsconfig.lib.json" },
    { "path": "../client/tsconfig.app.json" }
  ]
}
