{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "../../dist/out-tsc",
    "sourceMap": false,
    "module": "commonjs",
    "moduleResolution": "node10"
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.d.ts"
  ],
  "references": [
    { "path": "../../libs/shared/validation-schemas" },
    { "path": "../../libs/shared/dto" },
    { "path": "../../libs/client/server-communication" },
    { "path": "../../libs/client/store" },
    { "path": "../client" }
  ]
}
